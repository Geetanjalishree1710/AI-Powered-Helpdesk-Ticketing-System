# Environment: Production
# Note: Use this as a reference. Never commit sensitive values.

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/helpdesk?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Security (use a strong 32+ character random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-production-secret-key-min-32-characters-recommended-64

# Session Security (optional)
SESSION_SECRET=your-session-secret-key

# Database Connection Pool (optional)
MONGO_POOL_SIZE=10

# Application
APP_NAME=AI-Powered Helpdesk
APP_URL=https://your-domain.com

# Logging
LOG_LEVEL=info

# Email (optional - for future notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# API Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
