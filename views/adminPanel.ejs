<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | Helpdesk Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-body">
    <% const roleLabel = user && user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : "Admin"; %>

        <div class="dashboard-shell">
            <aside class="dashboard-sidebar" id="dashboardSidebar">
                <div class="brand-wrap">
                    <div class="brand-logo"><i class="bi bi-headset"></i></div>
                    <div>
                        <p class="brand-title">Helpdesk Pro</p>
                        <p class="brand-subtitle">Ticket Intelligence</p>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    <p class="nav-section">Main</p>
                    <a href="/dashboard" class="nav-item"><i class="bi bi-grid"></i> Dashboard</a>
                    <a href="/admin/panel" class="nav-item active"><i class="bi bi-shield-check"></i> Admin Panel</a>
                    <a href="/tickets" class="nav-item"><i class="bi bi-ticket-detailed"></i> Tickets</a>
                    <a href="/users" class="nav-item"><i class="bi bi-people"></i> Users</a>
                    <a href="/logout" class="nav-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </nav>
            </aside>

            <main class="dashboard-main">
                <header class="dashboard-topbar">
                    <div class="topbar-left">
                        <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Toggle menu">
                            <i class="bi bi-list"></i>
                        </button>
                        <div>
                            <h1 class="page-title">Admin Panel</h1>
                            <p class="page-subtitle">Manage all requests and update their status</p>
                        </div>
                    </div>

                    <div class="topbar-right">
                        <div class="user-pill">
                            <i class="bi bi-person-circle"></i>
                            <span><%= roleLabel %></span>
                        </div>
                    </div>
                </header>

                <section class="panel-card tickets-panel">
                    <div class="panel-head table-head">
                        <h2>Request Queue</h2>
                        <% if (message) { %>
                            <span class="users-feedback"><%= message %></span>
                            <% } %>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle dashboard-table" id="adminTicketTable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Title</th>
                                    <th>Requested By</th>
                                    <th>Status</th>
                                    <th>Created At</th>
                                    <th>Update Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!tickets || tickets.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No requests found.</td>
                                    </tr>
                                    <% } %>

                                        <% (tickets || []).forEach(ticket => { %>
                                            <tr>
                                                <td>#
                                                    <%= String(ticket._id || "").slice(-6) %>
                                                </td>
                                                <td>
                                                    <%= ticket.title || "Untitled" %>
                                                </td>
                                                <td>
                                                    <div>
                                                        <%= ticket.createdBy && ticket.createdBy.name ? ticket.createdBy.name : "Unknown" %>
                                                    </div>
                                                    <small class="text-muted"><%= ticket.createdBy && ticket.createdBy.email ? ticket.createdBy.email : "No email" %></small>
                                                </td>
                                                <td>
                                                    <span class="pill status <%= (ticket.status || " ").toLowerCase().replace(/\s+/g, '-') %>"><%= ticket.status || "Open" %></span>
                                                </td>
                                                <td>
                                                    <%= ticket.createdAt ? new Date(ticket.createdAt).toLocaleDateString() : "-" %>
                                                </td>
                                                <td>
                                                    <form action="/admin/tickets/<%= ticket._id %>/status" method="POST" class="status-form-inline">
                                                        <select name="status" class="form-select form-select-sm status-select">
                                                    <% statusOptions.forEach(option => { %>
                                                        <option value="<%= option %>" <%= ticket.status === option ? "selected" : "" %>><%= option %></option>
                                                    <% }) %>
                                                </select>
                                                        <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </section>
            </main>
        </div>

        <script>
            const sidebarToggle = document.getElementById("sidebarToggle");
            const sidebar = document.getElementById("dashboardSidebar");

            if (sidebarToggle && sidebar) {
                sidebarToggle.addEventListener("click", () => {
                    sidebar.classList.toggle("sidebar-open");
                });
            }
        </script>
</body>

</html>