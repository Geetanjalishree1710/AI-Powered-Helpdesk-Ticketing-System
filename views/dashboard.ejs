<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Helpdesk Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-body">
    <%
        const safeTickets = Array.isArray(tickets) ? tickets : [];
        const totalCount = stats && typeof stats.total === "number" ? stats.total : safeTickets.length;
        const openCount = safeTickets.filter(t => t.status === "Open").length;
        const inProgressCount = safeTickets.filter(t => t.status === "In Progress").length;
        const resolvedCount = safeTickets.filter(t => t.status === "Resolved").length;
        const closedCount = safeTickets.filter(t => t.status === "Closed").length;

        const categoryMap = {};
        safeTickets.forEach(ticket => {
            const name = ticket.category || "Other";
            categoryMap[name] = (categoryMap[name] || 0) + 1;
        });
        const categoryLabels = Object.keys(categoryMap).length ? Object.keys(categoryMap) : ["No Data"];
        const categoryValues = Object.keys(categoryMap).length ? Object.values(categoryMap) : [1];
        const roleLabel = user && user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : "User";
    %>

        <div class="dashboard-shell">
            <aside class="dashboard-sidebar" id="dashboardSidebar">
                <div class="brand-wrap">
                    <div class="brand-logo"><i class="bi bi-headset"></i></div>
                    <div>
                        <p class="brand-title">Helpdesk Pro</p>
                        <p class="brand-subtitle">Ticket Intelligence</p>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    <p class="nav-section">Main</p>
                    <a href="/dashboard" class="nav-item active"><i class="bi bi-grid"></i> Dashboard</a>
                    <% if (user && user.role === "admin") { %>
                        <a href="/admin/panel" class="nav-item"><i class="bi bi-shield-check"></i> Admin Panel</a>
                        <% } else { %>
                            <a href="/user/panel" class="nav-item"><i class="bi bi-person"></i> User Panel</a>
                            <% } %>
                                <a href="/tickets" class="nav-item"><i class="bi bi-ticket-detailed"></i> Tickets</a>
                                <a href="/create-ticket" class="nav-item"><i class="bi bi-plus-square"></i> CreateTicket</a>
                                <% if (user && user.role === "admin") { %>
                                    <a href="/users" class="nav-item"><i class="bi bi-people"></i> Users</a>
                                    <% } %>
                                        <a href="/logout" class="nav-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </nav>
            </aside>

            <main class="dashboard-main">
                <header class="dashboard-topbar">
                    <div class="topbar-left">
                        <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Toggle menu">
                        <i class="bi bi-list"></i>
                    </button>
                        <div>
                            <h1 class="page-title">Dashboard</h1>
                            <p class="page-subtitle">Operational overview of your support pipeline</p>
                        </div>
                    </div>

                    <div class="topbar-right">
                        <div class="user-pill">
                            <i class="bi bi-person-circle"></i>
                            <span><%= roleLabel %></span>
                        </div>
                        <a href="/create-ticket" class="btn btn-primary new-ticket-btn">
                            <i class="bi bi-plus-lg"></i> New Ticket
                        </a>
                    </div>
                </header>

                <section class="stats-grid">
                    <article class="metric-card metric-blue">
                        <p class="metric-label">Total Tickets</p>
                        <h3>
                            <%= totalCount %>
                        </h3>
                        <span class="metric-foot">All records</span>
                    </article>
                    <article class="metric-card metric-cyan">
                        <p class="metric-label">Open Tickets</p>
                        <h3>
                            <%= openCount %>
                        </h3>
                        <span class="metric-foot">Need assignment</span>
                    </article>
                    <article class="metric-card metric-amber">
                        <p class="metric-label">In Progress</p>
                        <h3>
                            <%= inProgressCount %>
                        </h3>
                        <span class="metric-foot">Under investigation</span>
                    </article>
                    <article class="metric-card metric-green">
                        <p class="metric-label">Resolved + Closed</p>
                        <h3>
                            <%= resolvedCount + closedCount %>
                        </h3>
                        <span class="metric-foot">Completed work</span>
                    </article>
                </section>

                <section class="analytics-grid">
                    <article class="panel-card panel-large">
                        <div class="panel-head">
                            <h2>Status Analytics</h2>
                            <span>This month</span>
                        </div>
                        <canvas id="statusChart" height="110"></canvas>
                    </article>

                    <article class="panel-card panel-medium">
                        <div class="panel-head">
                            <h2>Category Split</h2>
                        </div>
                        <canvas id="categoryChart" height="190"></canvas>
                    </article>

                    <article class="panel-card panel-medium">
                        <div class="panel-head">
                            <h2>Recent Activity</h2>
                        </div>
                        <ul class="activity-list">
                            <% if (safeTickets.length === 0) { %>
                                <li class="activity-item">
                                    <span class="activity-dot dot-muted"></span>
                                    <div>
                                        <p>No recent ticket activity found.</p>
                                        <small>Create your first ticket to start tracking.</small>
                                    </div>
                                </li>
                                <% } %>

                                    <% safeTickets.slice(0, 5).forEach(ticket => { %>
                                        <li class="activity-item">
                                            <span class="activity-dot <%= (ticket.status || '').toLowerCase().replace(/\s+/g, '-') %>"></span>
                                            <div>
                                                <p>
                                                    <%= ticket.title %>
                                                </p>
                                                <small><%= ticket.status || "Open" %> | <%= ticket.priority || "Medium" %></small>
                                            </div>
                                        </li>
                                        <% }) %>
                        </ul>
                    </article>
                </section>

                <section class="panel-card tickets-panel">
                    <div class="panel-head table-head">
                        <h2>All Tickets</h2>
                        <input type="search" id="ticketSearch" class="form-control search-input" placeholder="Search by title, status or category">
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle dashboard-table" id="ticketTable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Title</th>
                                    <th>Category</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Created At</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (safeTickets.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No tickets available.</td>
                                    </tr>
                                    <% } %>
                                        <% safeTickets.forEach(ticket => { %>
                                            <tr>
                                                <td>#
                                                    <%= String(ticket._id || "").slice(-6) %>
                                                </td>
                                                <td>
                                                    <%= ticket.title %>
                                                </td>
                                                <td><span class="pill neutral"><%= ticket.category || "General" %></span></td>
                                                <td><span class="pill <%= (ticket.priority || " ").toLowerCase() %>"><%= ticket.priority || "Medium" %></span></td>
                                                <td><span class="pill status <%= (ticket.status || " ").toLowerCase().replace(/\s+/g, '-') %>"><%= ticket.status || "Open" %></span></td>
                                                <td>
                                                    <%= ticket.createdAt ? new Date(ticket.createdAt).toLocaleDateString() : "-" %>
                                                </td>
                                            </tr>
                                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </section>
            </main>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            const statusCtx = document.getElementById("statusChart");
            const categoryCtx = document.getElementById("categoryChart");

            if (statusCtx) {
                new Chart(statusCtx, {
                    type: "line",
                    data: {
                        labels: ["Open", "In Progress", "Resolved", "Closed"],
                        datasets: [{
                            label: "Tickets by Status",
                            data: [<%= openCount %>, <%= inProgressCount %>, <%= resolvedCount %>, <%= closedCount %>],
                            borderColor: "#2d7ff9",
                            backgroundColor: "rgba(45, 127, 249, 0.18)",
                            fill: true,
                            tension: 0.35,
                            pointRadius: 4,
                            pointBackgroundColor: "#2d7ff9"
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }

            if (categoryCtx) {
                new Chart(categoryCtx, {
                    type: "doughnut",
                    data: {
                        labels: <%- JSON.stringify(categoryLabels) %>,
                        datasets: [{
                            data: <%- JSON.stringify(categoryValues) %>,
                            backgroundColor: ["#2d7ff9", "#1db7c0", "#f8b320", "#37b36b", "#f56c6c", "#7a88a1"]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: "55%",
                        plugins: {
                            legend: {
                                position: "bottom",
                                labels: {
                                    boxWidth: 10,
                                    usePointStyle: true
                                }
                            }
                        }
                    }
                });
            }

            const searchInput = document.getElementById("ticketSearch");
            const ticketRows = document.querySelectorAll("#ticketTable tbody tr");

            if (searchInput) {
                searchInput.addEventListener("input", (event) => {
                    const term = event.target.value.trim().toLowerCase();
                    ticketRows.forEach((row) => {
                        const text = row.textContent.toLowerCase();
                        row.style.display = text.includes(term) ? "" : "none";
                    });
                });
            }

            const sidebarToggle = document.getElementById("sidebarToggle");
            const sidebar = document.getElementById("dashboardSidebar");

            if (sidebarToggle && sidebar) {
                sidebarToggle.addEventListener("click", () => {
                    sidebar.classList.toggle("sidebar-open");
                });
            }
        </script>
</body>

</html>