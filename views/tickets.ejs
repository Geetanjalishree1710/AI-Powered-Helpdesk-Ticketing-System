<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tickets - Helpdesk System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="container mt-4">
        <h3 class="mb-4">Ticket Management</h3>

        <!-- Create Ticket -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>Create New Ticket</h5>
            </div>
            <div class="card-body">
                <form action="/tickets" method="POST">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" name="title" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Create Ticket</button>
                </form>
            </div>
        </div>

        <!-- Tickets List -->
        <div class="card">
            <div class="card-header">
                <h5>All Tickets</h5>
            </div>
            <div class="card-body">
                <% if (tickets && tickets.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% tickets.forEach(ticket => { %>
                                    <tr>
                                        <td>
                                            <%= ticket.title %>
                                        </td>
                                        <td>
                                            <%= ticket.description %>
                                        </td>
                                        <td>
                                            <span class="badge <%= ticket.status === 'Open' ? 'bg-warning' : 'bg-success' %>">
                                                <%= ticket.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= ticket.createdAt ? ticket.createdAt.toDateString() : 'N/A' %>
                                        </td>
                                        <td>
                                            <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
                                                <form action="/tickets/resolve/<%= ticket._id %>" method="POST" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm btn-success">Resolve</button>
                                                </form>
                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <p>No tickets found.</p>
                        <% } %>
            </div>
        </div>

        <div class="mt-3">
            <a href="/dashboard" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>
</body>

</html>