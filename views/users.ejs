<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users | Helpdesk Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-body">
    <% const roleLabel = user && user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : "Admin"; %>

        <div class="dashboard-shell">
            <aside class="dashboard-sidebar">
                <div class="brand-wrap">
                    <div class="brand-logo"><i class="bi bi-headset"></i></div>
                    <div>
                        <p class="brand-title">Helpdesk Pro</p>
                        <p class="brand-subtitle">Ticket Intelligence</p>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    <p class="nav-section">Main</p>
                    <a href="/dashboard" class="nav-item"><i class="bi bi-grid"></i> Dashboard</a>
                    <a href="/tickets" class="nav-item"><i class="bi bi-ticket-detailed"></i> Tickets</a>
                    <a href="/create-ticket" class="nav-item"><i class="bi bi-plus-square"></i> Create Ticket</a>
                    <a href="/users" class="nav-item active"><i class="bi bi-people"></i> Users</a>
                    <a href="/logout" class="nav-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </nav>
            </aside>

            <main class="dashboard-main">
                <header class="dashboard-topbar">
                    <div class="topbar-left">
                        <div>
                            <h1 class="page-title">User Management</h1>
                            <p class="page-subtitle">Promote or demote users by role</p>
                        </div>
                    </div>

                    <div class="topbar-right">
                        <div class="user-pill">
                            <i class="bi bi-person-circle"></i>
                            <span><%= roleLabel %></span>
                        </div>
                    </div>
                </header>

                <section class="panel-card tickets-panel">
                    <div class="panel-head table-head">
                        <h2>All Users</h2>
                        <% if (message) { %>
                            <span class="users-feedback"><%= message %></span>
                            <% } %>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle dashboard-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Current Role</th>
                                    <th>Update Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(target => { %>
                                    <tr>
                                        <td>
                                            <%= target.name || "-" %>
                                        </td>
                                        <td>
                                            <%= target.email %>
                                        </td>
                                        <td>
                                            <span class="pill <%= target.role === " admin " ? "high " : "low " %>">
                                            <%= target.role.charAt(0).toUpperCase() + target.role.slice(1) %>
                                        </span>
                                        </td>
                                        <td>
                                            <form action="/users/<%= target._id %>/role" method="POST" class="role-form-inline">
                                                <select name="role" class="form-select form-select-sm role-select">
                                                <option value="user" <%= target.role === "user" ? "selected" : "" %>>User</option>
                                                <option value="admin" <%= target.role === "admin" ? "selected" : "" %>>Admin</option>
                                            </select>
                                                <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </section>
            </main>
        </div>
</body>

</html>